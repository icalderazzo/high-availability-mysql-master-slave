datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="admin:admin"
    mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    have_compress=true
    poll_timeout=2000
    interfaces="0.0.0.0:6033"
    default_schema="classicmodels"
    stacksize=1048576
    server_version="8.0.42"
    connect_timeout_server=3000
    monitor_username="root"
    monitor_password="your_super_secure_root_password"
    monitor_history=600000
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    monitor_read_only_interval=1500
    monitor_read_only_timeout=500
    ping_interval_server_msec=120000
    ping_timeout_server=500
    commands_stats=true
    sessions_sort=true
    connect_retries_on_failure=10
}

mysql_servers=
(
    {
        address="mysql-master"
        port=3306
        hostgroup=0
        max_connections=200
        comment="Master Server - All queries except CALL"
    },
    {
        address="mysql-slave"
        port=3306
        hostgroup=1
        max_connections=200
        comment="Slave Server - CALL statements only"
    }
)

mysql_users=
(
    {
        username="ordersapp"
        password="ordersapp_password"
        default_hostgroup=0
        active=1
        max_connections=1000
    }
)

mysql_query_rules=
(
    {
        rule_id=10
        active=1
        match_pattern="^CALL"
        destination_hostgroup=1
        apply=1
        comment="Route CALL statements to slave for reporting"
    },
    {
        rule_id=100
        active=1
        match_pattern=".*"
        destination_hostgroup=0
        apply=1
        comment="Default: all other queries to master"
    }
)
